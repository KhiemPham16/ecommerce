                "responses": {
                    "200": { "description": "Delete category successfully" }
                }
            }
        },
        "/products": {
            "get": {
                "summary": "Get products",
                "tags": ["Products"],
                "parameters": [
                    { "name": "keyword", "in": "query", "schema": { "type": "string" }, "example": "clean" },
                    { "name": "categoryId", "in": "query", "schema": { "type": "string" } },
                    { "name": "minPrice", "in": "query", "schema": { "type": "number" } },
                    { "name": "maxPrice", "in": "query", "schema": { "type": "number" } },
                    { "name": "page", "in": "query", "schema": { "type": "number" }, "example": 1 },
                    { "name": "limit", "in": "query", "schema": { "type": "number" }, "example": 10 }
                ],
                "responses": {
                    "200": { "description": "Get products successfully" }
                }
            },
            "post": {
                "summary": "Create product",
                "tags": ["Products"],
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["title", "categoryId", "author", "price"],
                                "properties": {
                                    "title": { "type": "string", "example": "Clean Code" },
                                    "categoryId": { "type": "string", "example": "665f1a2b3c4d5e6f78901234" },
                                    "author": { "type": "string", "example": "Robert C. Martin" },
                                    "publisher": { "type": "string", "example": "Prentice Hall" },
                                    "isbn": { "type": "string", "example": "9780132350884" },
                                    "description": { "type": "string", "example": "Cuốn sách kinh điển về Clean Code" },
                                    "thumbnail": { "type": "string", "example": "/uploads/products/clean-code.jpg" },
                                    "images": {
                                        "type": "array",
                                        "items": { "type": "string" },
                                        "example": ["/uploads/products/clean-code-1.jpg"]
                                    },
                                    "price": { "type": "number", "example": 250000 },
                                    "stock": { "type": "number", "example": 100 },
                                    "isFeatured": { "type": "boolean", "example": true },
                                    "isActive": { "type": "boolean", "example": true }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Create product successfully" }
                }
            }
        },
