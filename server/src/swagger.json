            "patch": {
                "summary": "Update user",
                "tags": ["Admin - Manager"],
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "fullName": { "type": "string", "example": "Nguyễn Văn B" },
                                    "role": {
                                        "type": "string",
                                        "enum": ["admin", "manager", "employee", "customer"],
                                        "example": "manager"
                                    },
                                    "gender": {
                                        "type": "string",
                                        "enum": ["male", "female", "other"],
                                        "example": "male"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Update user successfully" },
                    "400": { "description": "Invalid input" },
                    "404": { "description": "User not found" }
                }
            },
            "delete": {
                "summary": "Delete user",
                "tags": ["Admin - Manager"],
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "Delete user successfully" },
                    "404": { "description": "User not found" }
                }
            }
        },
        "/address/me": {
            "get": {
                "summary": "Get current user address",
                "tags": ["Address"],
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "Get address successfully" },
                    "401": { "description": "Unauthorized" }
                }
            },
            "put": {
                "summary": "Update current user address",
                "tags": ["Address"],
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "receiverName",
                                    "receiverPhone",
                                    "provinceCity",
                                    "ward",
                                    "specificAddress"
                                ],
                                "properties": {
                                    "receiverName": { "type": "string", "example": "Nguyễn Văn A" },
                                    "receiverPhone": { "type": "string", "example": "0900000000" },
                                    "provinceCity": { "type": "string", "example": "TP.HCM" },
                                    "ward": { "type": "string", "example": "Phường Bến Nghé" },
                                    "specificAddress": { "type": "string", "example": "123 Nguyễn Huệ" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Update address successfully" },
                    "400": { "description": "Invalid input" },
                    "401": { "description": "Unauthorized" }
                }
            }
        },
        "/categories": {
            "get": {
                "summary": "Get categories",
                "tags": ["Categories"],
                "responses": {
                    "200": { "description": "Get categories successfully" }
                }
            },
            "post": {
                "summary": "Create category",
                "tags": ["Categories"],
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["name"],
                                "properties": {
                                    "name": { "type": "string", "example": "Sách Công Nghệ" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Create category successfully" },
                    "403": { "description": "Forbidden" }
                }
            }
        },
        "/categories/{id}": {
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "schema": { "type": "string" }
                }
            ],
            "get": {
                "summary": "Get category by id",
                "tags": ["Categories"],
                "responses": {
                    "200": { "description": "Get category successfully" },
                    "404": { "description": "Category not found" }
