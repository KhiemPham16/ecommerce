        },
        "/users/{id}": {
            "parameters": [
                {
                    "name": "id",
                    "in": "path",
                    "required": true,
                    "schema": { "type": "string" },
                    "example": "665f1a2b3c4d5e6f78901234"
                }
            ],
            "get": {
                "summary": "Get user by id",
                "tags": ["Admin - Manager"],
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "Get user successfully" },
