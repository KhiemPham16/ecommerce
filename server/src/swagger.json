        },
        "/orders": {
            "post": {
                "summary": "Create order",
                "tags": ["Orders"],
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["addressId", "items"],
                                "properties": {
                                    "addressId": {
                                        "type": "string",
                                        "example": "665f1a2b3c4d5e6f78901234"
                                    },
                                    "items": {
                                        "type": "array",
                                        "items": {
                                            "type": "object",
                                            "required": ["productId", "quantity"],
                                            "properties": {
                                                "productId": {
                                                    "type": "string",
                                                    "example": "665f1a2b3c4d5e6f78905678"
                                                },
                                                "quantity": {
                                                    "type": "number",
                                                    "example": 2
                                                }
                                            }
                                        }
                                    },
                                    "paymentMethod": {
                                        "type": "string",
                                        "enum": ["cod"],
                                        "example": "cod"
                                    },
                                    "note": {
                                        "type": "string",
                                        "example": "Giao giờ hành chính"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": { "description": "Create order successfully" },
                    "400": { "description": "Invalid input" },
                    "401": { "description": "Unauthorized" }
                }
            },
            "get": {
                "summary": "Get all orders",
                "tags": ["Orders"],
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "Get orders successfully" },
                    "403": { "description": "Forbidden" }
                }
            }
        },
