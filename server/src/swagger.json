        "/coupons/validate": {
            "post": {
                "summary": "Validate coupon",
                "tags": ["Coupons"],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["code", "totalAmount"],
                                "properties": {
                                    "code": {
                                        "type": "string",
                                        "example": "KHIEM50K"
                                    },
                                    "totalAmount": {
                                        "type": "number",
                                        "example": 500000
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": { "description": "Validate coupon successfully" },
                    "400": { "description": "Invalid coupon" },
                    "404": { "description": "Coupon not found" }
                }
            }
        },
        "/coupons": {
            "get": {
                "summary": "Get coupons",
                "tags": ["Coupons"],
                "security": [{ "BearerAuth": [] }],
                "responses": {
                    "200": { "description": "Get coupons successfully" },
                    "403": { "description": "Forbidden" }
                }
            },
            "post": {
                "summary": "Create coupon",
                "tags": ["Coupons"],
                "security": [{ "BearerAuth": [] }],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["couponType", "type", "value", "expiresAt"],
                                "properties": {
                                    "couponType": {
                                        "type": "string",
                                        "enum": ["holiday", "random", "custom"],
                                        "example": "custom"
                                    },
                                    "code": {
                                        "type": "string",
                                        "example": "BOOKTOK20"
                                    },
                                    "type": {
                                        "type": "string",
                                        "enum": ["percent", "fixed"],
                                        "example": "percent"
                                    },
                                    "value": {
                                        "type": "number",
                                        "example": 20
                                    },
                                    "minOrderAmount": {
                                        "type": "number",
                                        "example": 200000
                                    },
                                    "maxDiscountAmount": {
                                        "type": "number",
                                        "example": 50000
                                    },
                                    "usageLimit": {
                                        "type": "number",
                                        "example": 300
                                    },
                                    "startsAt": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2026-08-08T00:00:00.000Z"
                                    },
                                    "expiresAt": {
                                        "type": "string",
                                        "format": "date-time",
                                        "example": "2026-12-31T23:59:59.000Z"
                                    },
                                    "isActive": {
                                        "type": "boolean",
                                        "example": true
